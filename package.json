{
  "$schema": "https://json.schemastore.org/package",
  "name": "verdaccio-openid",
  "version": "0.17.2",
  "repository": "https://github.com/kuoruan/verdaccio-openid",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "author": {
    "name": "Xingwang Liao",
    "email": "kuoruan@gmail.com"
  },
  "description": "A UI for OIDC authentication for Verdaccio, a fork of verdaccio-github-oauth-ui",
  "keywords": [
    "verdaccio",
    "oidc",
    "openid",
    "authentication",
    "oauth",
    "oauth2",
    "ui"
  ],
  "main": "./dist/server/index.js",
  "module": "./dist/server/index.mjs",
  "bin": "./dist/verdaccio-openid.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production tsdown",
    "start": "cross-env DEBUG='verdaccio:*' node_modules/verdaccio/bin/verdaccio -c verdaccio/verdaccio.yml",
    "start:5": "cross-env DEBUG='verdaccio:*' node_modules/verdaccio5/bin/verdaccio -c verdaccio5/verdaccio.yml",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest --run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "@isaacs/ttlcache": "^2.1.5",
    "@verdaccio/auth": "^8.0.4",
    "@verdaccio/config": "^8.1.2",
    "@verdaccio/core": "^8.1.2",
    "@verdaccio/url": "^13.0.3",
    "debug": "^4.4.3",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "global-agent": "^4.1.3",
    "ioredis": "^5.11.1",
    "minimist": "^1.2.8",
    "ms": "^2.1.3",
    "node-persist": "^4.0.4",
    "open": "^11.0.0",
    "openid-client": "^6.8.4",
    "picocolors": "^1.1.1",
    "serve-static": "^2.2.1",
    "stable-hash": "^0.0.6",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/global-agent": "^3.0.0",
    "@types/lodash": "^4.17.24",
    "@types/minimist": "^1.2.5",
    "@types/ms": "^2.1.0",
    "@types/node-persist": "^3.1.8",
    "@types/serve-static": "^2.2.0",
    "@verdaccio/types": "13.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-next": "^0.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "verdaccio": "^6.7.4",
    "verdaccio-htpasswd": "^13.0.3",
    "verdaccio-openid": "file:",
    "verdaccio5": "npm:verdaccio@5.0.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "verdaccio": "^5.0.0||^6.0.0||^7.0.0-next-0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "abab": "npm:@nolyfill/abab@^1",
      "array-flatten": "npm:@nolyfill/array-flatten@^1",
      "es-set-tostringtag": "npm:@nolyfill/es-set-tostringtag@^1",
      "globalthis": "npm:@nolyfill/globalthis@^1",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "isarray": "npm:@nolyfill/isarray@^1",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1",
      "side-channel": "npm:@nolyfill/side-channel@^1",
      "hasown": "npm:@nolyfill/hasown@^1"
    }
  }
}
